{
  "name": "yoani-pc-redirect-chrext",
  "version": "0.1.0",
  "private": true,
  "description": "Chrome extension that redirects specific hosts to replacement hosts using declarativeNetRequest.",
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=22.22.1"
  },
  "scripts": {
    "predev": "pnpm generate:rules",
    "dev": "wxt",
    "generate:rules": "tsx src/dnr/build-rules.ts",
    "prebuild": "pnpm generate:rules",
    "build": "wxt build",
    "prezip": "pnpm generate:rules",
    "zip": "wxt zip",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@types/node": "25.5.0",
    "tsx": "4.20.6",
    "typescript": "5.9.3",
    "vitest": "4.1.0",
    "wxt": "0.20.18"
  },
  "license": "MIT"
}

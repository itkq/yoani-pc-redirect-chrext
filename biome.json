{
  "$schema": "https://biomejs.dev/schemas/2.4.7/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "files": {
    "includes": [
      "**",
      "!dist",
      "!.output",
      "!.wxt",
      "!node_modules",
      "!public/rules/redirect-rules.json"
    ]
  }
}
